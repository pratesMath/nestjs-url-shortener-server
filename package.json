{
	"name": "nestjs-url-shortener-server",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"biome:format": "npx @biomejs/biome format --write",
		"biome:lint": "npx @biomejs/biome lint --write",
		"biome:check": "npx @biomejs/biome check --write",
		"typecheck": "tsc --noEmit",
		"db:generate": "npx drizzle-kit generate",
		"db:migrate": "npx drizzle-kit migrate",
		"db:studio": "npx drizzle-kit studio",
		"db:seed": "tsx --env-file=.env src/config/database/drizzle/seed.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
		"test:e2e": "vitest run --config ./vitest.config.e2e.ts",
		"test:e2e:watch": "vitest --config ./vitest.config.e2e.ts"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.0.1",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.0.1",
		"@types/pg": "^8.20.0",
		"argon2": "^0.44.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"date-fns": "^4.1.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.1",
		"passport-jwt": "^4.0.1",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@faker-js/faker": "^10.3.0",
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@swc/core": "^1.15.18",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.10.7",
		"@types/supertest": "^6.0.2",
		"globals": "^16.0.0",
		"jest": "^30.0.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"unplugin-swc": "^1.5.9",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
